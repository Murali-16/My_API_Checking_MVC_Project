@{
    ViewBag.Title = "API Console";
}
<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/js/bootstrap.min.js"></script>
<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        font-family: 'Segoe UI', 'Roboto', sans-serif;
        font-size: 12px;
        line-height: 1.5;
        background: #f3f4f6;
        color: #1f2937;
        overflow: hidden;
    }

    #app-shell {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    /* ── Top Nav ── */
    #top-nav {
        background: #1e1e2e;
        border-bottom: 1px solid #2d2d3f;
        padding: 0 14px;
        display: flex;
        align-items: center;
        height: 46px;
        flex-shrink: 0;
        gap: 10px;
        z-index: 100;
    }

        #top-nav .brand {
            font-weight: 700;
            font-size: 18px;
            color: #f97316;
            letter-spacing: -0.3px;
        }

            #top-nav .brand span {
                color: #94a3b8;
                font-size: 12px;
                font-weight: 400;
                margin-left: 6px;
            }

    #sidebar-toggle {
        background: none;
        border: none;
        font-size: 18px;
        color: #64748b;
        cursor: pointer;
        padding: 0 4px;
        border-radius: 4px;
    }

        #sidebar-toggle:hover {
            color: #f97316;
            background: #2d2d3f;
        }

    /* ── Tab Bar ── */
    #tab-bar {
        background: #16213e;
        border-bottom: 1px solid #0f3460;
        display: flex;
        align-items: flex-end;
        padding: 0 8px;
        height: 36px;
        flex-shrink: 0;
        overflow-x: auto;
        gap: 1px;
    }

        #tab-bar::-webkit-scrollbar {
            height: 3px;
        }

        #tab-bar::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 2px;
        }

    .req-tab {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0 10px;
        height: 30px;
        border: 1px solid transparent;
        border-bottom: none;
        border-radius: 6px 6px 0 0;
        cursor: pointer;
        font-size: 12px;
        color: #64748b;
        background: transparent;
        white-space: nowrap;
        user-select: none;
        transition: background 0.1s;
        flex-shrink: 0;
    }

        .req-tab:hover {
            background: #1e293b;
            color: #e2e8f0;
        }

        .req-tab.active {
            background: #f3f4f6;
            border-color: #0f3460;
            border-bottom-color: #f3f4f6;
            color: #111827;
            font-weight: 500;
            position: relative;
            bottom: -1px;
        }

        .req-tab .tab-method {
            font-size: 9px;
            font-weight: 700;
            padding: 1px 4px;
            border-radius: 3px;
        }

    .tab-close {
        font-size: 14px;
        line-height: 1;
        color: #475569;
        cursor: pointer;
        padding: 0 2px;
        border-radius: 3px;
        margin-left: 2px;
    }

        .tab-close:hover {
            background: #fee2e2;
            color: #dc2626;
        }

    #btn-new-tab {
        height: 24px;
        padding: 0 8px;
        border: 1px dashed #334155;
        border-radius: 4px;
        font-size: 18px;
        color: #475569;
        cursor: pointer;
        background: transparent;
        line-height: 1;
        margin-bottom: 4px;
        transition: all 0.15s;
    }

        #btn-new-tab:hover {
            border-color: #f97316;
            color: #f97316;
        }

    /* ── Body Layout ── */
    #body-layout {
        display: flex;
        flex: 1;
        overflow: hidden;
    }

    /* ── Sidebar ── */
    #sidebar {
        width: 260px;
        flex-shrink: 0;
        background: #1e1e2e;
        border-right: 1px solid #2d2d3f;
        display: flex;
        flex-direction: column;
        transition: width 0.2s ease;
        overflow: hidden;
    }

        #sidebar.collapsed {
            width: 0;
        }

    #sidebar-header {
        padding: 10px 12px 8px;
        border-bottom: 1px solid #2d2d3f;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

        #sidebar-header .hdr-title {
            font-weight: 600;
            font-size: 11px;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

    #btn-add-collection {
        background: #f97316;
        color: #fff;
        border: none;
        border-radius: 5px;
        padding: 3px 10px;
        font-size: 11px;
        cursor: pointer;
        font-weight: 500;
        letter-spacing: 0.2px;
    }

        #btn-add-collection:hover {
            background: #ea6c07;
        }

    #collection-list {
        flex: 1;
        overflow-y: auto;
        padding: 6px 0;
    }

        #collection-list::-webkit-scrollbar {
            width: 4px;
        }

        #collection-list::-webkit-scrollbar-thumb {
            background: #2d2d3f;
            border-radius: 2px;
        }

    /* Collection group */
    .col-group {
        margin-bottom: 2px;
    }

    .col-group-hdr {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 7px 10px;
        cursor: pointer;
        font-weight: 600;
        font-size: 12px;
        color: #94a3b8;
        border-radius: 5px;
        margin: 0 4px;
        user-select: none;
        position: relative;
    }

        .col-group-hdr:hover {
            background: #2d2d3f;
            color: #e2e8f0;
        }

        .col-group-hdr .col-icon {
            font-size: 10px;
            color: #475569;
            transition: transform 0.2s;
            flex-shrink: 0;
        }

        .col-group-hdr.open .col-icon {
            transform: rotate(90deg);
        }

        .col-group-hdr .col-name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .col-group-hdr .col-count {
            font-size: 10px;
            color: #475569;
            background: #2d2d3f;
            border-radius: 10px;
            padding: 0 6px;
            font-weight: 400;
        }

        .col-group-hdr .col-actions {
            display: none;
            gap: 2px;
            flex-shrink: 0;
        }

        .col-group-hdr:hover .col-actions {
            display: flex;
        }

    .col-act-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: #64748b;
        font-size: 13px;
        padding: 2px 4px;
        border-radius: 3px;
        line-height: 1;
    }

        .col-act-btn:hover {
            color: #f97316;
            background: rgba(249,115,22,0.1);
        }

        .col-act-btn.danger:hover {
            color: #ef4444;
            background: rgba(239,68,68,0.1);
        }

    /* Collection items */
    .col-items {
        display: none;
    }

        .col-items.open {
            display: block;
        }

    .col-item {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px 6px 28px;
        cursor: pointer;
        font-size: 12px;
        color: #64748b;
        border-radius: 4px;
        margin: 1px 4px;
        user-select: none;
        position: relative;
    }

        .col-item:hover {
            background: #2d2d3f;
            color: #e2e8f0;
        }

        .col-item.active {
            background: rgba(249,115,22,0.12);
            color: #f97316;
        }

        .col-item .item-method {
            font-size: 9px;
            font-weight: 700;
            padding: 1px 5px;
            border-radius: 3px;
            min-width: 34px;
            text-align: center;
            flex-shrink: 0;
        }

        .col-item .item-name {
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .col-item .item-actions {
            display: none;
            gap: 2px;
            flex-shrink: 0;
        }

        .col-item:hover .item-actions {
            display: flex;
        }

    .item-act-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: #64748b;
        font-size: 12px;
        padding: 1px 3px;
        border-radius: 3px;
        line-height: 1;
    }

        .item-act-btn:hover {
            color: #f97316;
        }

        .item-act-btn.danger:hover {
            color: #ef4444;
        }

    /* Method badge colours */
    .m-get {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .m-post {
        background: #d1fae5;
        color: #065f46;
    }

    .m-put {
        background: #fef3c7;
        color: #92400e;
    }

    .m-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .m-patch {
        background: #ede9fe;
        color: #5b21b6;
    }

    /* empty state */
    .sidebar-empty {
        padding: 24px 16px;
        text-align: center;
        color: #475569;
        font-size: 12px;
        line-height: 1.8;
    }

        .sidebar-empty .empty-icon {
            font-size: 28px;
            margin-bottom: 8px;
        }

    /* ── Main Panel ── */
    #main-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #f3f4f6;
    }

    /* ── Request Card ── */
    #req-card {
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
        padding: 12px 14px 0;
        flex-shrink: 0;
    }

    .url-row {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 10px;
    }

    #method {
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 6px 10px;
        font-weight: 700;
        font-size: 13px;
        cursor: pointer;
        outline: none;
        min-width: 90px;
        background: #f9fafb;
    }

    #url {
        flex: 1;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 6px 10px;
        font-size: 13px;
        outline: none;
        color: #111827;
        font-family: 'Consolas', monospace;
    }

        #url:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 2px #fed7aa44;
        }

    #btn-send {
        background: #f97316;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 6px 18px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        white-space: nowrap;
        position: relative;
        overflow: hidden;
        min-width: 72px;
        transition: background 0.2s;
    }

        #btn-send:hover {
            background: #ea6c07;
        }

        #btn-send.loading {
            background: #c2410c;
            pointer-events: none;
            opacity: 0.9;
        }

        #btn-send .btn-label {
            transition: opacity 0.15s;
        }

        #btn-send.loading .btn-label {
            opacity: 0;
        }

    #send-spinner {
        display: none;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
        width: 16px;
        height: 16px;
        border: 2.5px solid rgba(255,255,255,0.35);
        border-top-color: #fff;
        border-radius: 50%;
        animation: btn-spin 0.65s linear infinite;
    }

    #btn-send.loading #send-spinner {
        display: block;
    }

    @@keyframes btn-spin {
        to {
            transform: translate(-50%,-50%) rotate(360deg);
        }
    }

    #btn-save-req {
        background: transparent;
        color: #6b7280;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 12px;
        cursor: pointer;
        white-space: nowrap;
    }

        #btn-save-req:hover {
            border-color: #f97316;
            color: #f97316;
            background: #fff7ed;
        }

    /* ── Inner Tabs ── */
    .inner-tab-bar {
        display: flex;
        gap: 0;
        border-bottom: 1px solid #e5e7eb;
    }

    .inner-tab {
        padding: 7px 14px;
        font-size: 12px;
        color: #6b7280;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        font-weight: 400;
    }

        .inner-tab:hover {
            color: #374151;
        }

        .inner-tab.active {
            color: #f97316;
            border-bottom-color: #f97316;
            font-weight: 500;
        }

    .inner-tab-content {
        display: none;
        padding: 10px 0;
    }

        .inner-tab-content.active {
            display: block;
        }

    /* ── KV Table ── */
    .kv-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

        .kv-table th {
            color: #6b7280;
            font-weight: 500;
            padding: 4px 6px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
            font-size: 11px;
            letter-spacing: 0.3px;
        }

        .kv-table td {
            padding: 3px 4px;
            border-bottom: 1px solid #f3f4f6;
        }

        .kv-table input[type="text"] {
            width: 100%;
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            padding: 4px 7px;
            font-size: 12px;
            color: #111827;
            outline: none;
            background: #fafafa;
        }

            .kv-table input[type="text"]:focus {
                border-color: #f97316;
                background: #fff;
            }

        .kv-table input[type="checkbox"] {
            accent-color: #f97316;
            cursor: pointer;
        }

    .btn-add-row {
        background: none;
        border: 1px dashed #d1d5db;
        border-radius: 4px;
        padding: 3px 10px;
        font-size: 11px;
        color: #6b7280;
        cursor: pointer;
        margin-top: 6px;
    }

        .btn-add-row:hover {
            border-color: #f97316;
            color: #f97316;
        }

    .btn-del-row {
        background: none;
        border: none;
        color: #ef4444;
        cursor: pointer;
        font-size: 16px;
        padding: 0 4px;
    }

    /* ── Body Toolbar ── */
    .body-toolbar {
        display: flex;
        gap: 6px;
        margin-bottom: 6px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-body {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 5px;
        padding: 3px 10px;
        font-size: 11px;
        color: #374151;
        cursor: pointer;
        transition: all 0.12s;
    }

        .btn-body:hover {
            border-color: #f97316;
            color: #f97316;
            background: #fff7ed;
        }

        .btn-body.danger:hover {
            border-color: #ef4444;
            color: #ef4444;
            background: #fef2f2;
        }

    .detect-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 9px;
        border-radius: 20px;
        display: none;
    }

    .detect-json {
        background: #d1fae5;
        color: #065f46;
    }

    .detect-xml {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .detect-text {
        background: #f3f4f6;
        color: #6b7280;
    }

    #bodyValidMsg {
        font-size: 11px;
    }

    #bodyData {
        width: 100%;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 8px;
        font-family: 'Consolas', monospace;
        font-size: 12px;
        resize: vertical;
        min-height: 80px;
        color: #111827;
        outline: none;
    }

        #bodyData:focus {
            border-color: #f97316;
        }

        #bodyData.flash-ok {
            border-color: #34d399 !important;
        }

        #bodyData.flash-error {
            border-color: #f87171 !important;
        }

    /* ── Response Card ── */
    #res-card {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #ffffff;
        margin: 10px;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
    }

    #res-header {
        padding: 8px 14px;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
        font-size: 12px;
    }

    .status-badge {
        padding: 3px 10px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 12px;
    }

    .status-2xx {
        background: #dcfce7;
        color: #166534;
    }

    .status-4xx {
        background: #fef3c7;
        color: #92400e;
    }

    .status-5xx {
        background: #fee2e2;
        color: #991b1b;
    }

    .status-def {
        background: #e5e7eb;
        color: #374151;
    }

    #res-tabs {
        display: flex;
        border-bottom: 1px solid #e5e7eb;
        padding: 0 14px;
        flex-shrink: 0;
    }

    .res-tab {
        padding: 6px 12px;
        font-size: 12px;
        color: #6b7280;
        cursor: pointer;
        border-bottom: 2px solid transparent;
    }

        .res-tab:hover {
            color: #111827;
        }

        .res-tab.active {
            color: #f97316;
            border-bottom-color: #f97316;
            font-weight: 500;
        }

    #res-body-wrap {
        flex: 1;
        overflow-y: auto;
        padding: 12px 14px;
    }

    pre#response {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 12px;
        font-family: 'Consolas', monospace;
        font-size: 12px;
        color: #111827;
        white-space: pre-wrap;
        word-break: break-all;
        margin: 0;
    }

    .jk {
        color: #1d4ed8;
    }

    .js {
        color: #b45309;
    }

    .jn {
        color: #6d28d9;
    }

    .jb {
        color: #047857;
    }

    .jl {
        color: #9ca3af;
    }

    #res-headers-tab {
        padding: 10px 14px;
        overflow-y: auto;
        display: none;
        flex: 1;
    }

    .res-hdr-row {
        display: flex;
        gap: 8px;
        padding: 5px 0;
        border-bottom: 1px solid #f3f4f6;
        font-size: 12px;
    }

    .res-hdr-key {
        color: #1d4ed8;
        font-weight: 500;
        min-width: 200px;
        font-family: 'Consolas', monospace;
    }

    .res-hdr-val {
        color: #374151;
    }

    /* ── Page Loader ── */
    #page-loader {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(2px);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 14px;
    }

        #page-loader.show {
            display: flex;
        }

    .loader-ring {
        width: 52px;
        height: 52px;
        border: 5px solid #fed7aa;
        border-top-color: #f97316;
        border-radius: 50%;
        animation: ring-spin 0.75s linear infinite;
    }

    @@keyframes ring-spin {
        to {
            transform: rotate(360deg);
        }
    }

    .loader-text {
        font-size: 13px;
        font-weight: 600;
        color: #f97316;
        letter-spacing: 0.3px;
    }

    /* ── Context Menu ── */
    #ctx-menu {
        position: fixed;
        z-index: 8000;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        padding: 4px 0;
        min-width: 170px;
        display: none;
        animation: ctxFade 0.1s ease;
    }

    @@keyframes ctxFade {
        from {
            opacity: 0;
            transform: scale(0.96);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .ctx-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        font-size: 12px;
        color: #374151;
        cursor: pointer;
        transition: background 0.08s;
    }

        .ctx-item:hover {
            background: #f3f4f6;
            color: #111827;
        }

        .ctx-item .ctx-icon {
            font-size: 14px;
            width: 16px;
            text-align: center;
        }

        .ctx-item.danger {
            color: #dc2626;
        }

            .ctx-item.danger:hover {
                background: #fef2f2;
            }

    .ctx-sep {
        height: 1px;
        background: #e5e7eb;
        margin: 4px 0;
    }

    /* ── Modal ── */
    .modal-header {
        background: #1e1e2e;
        color: #fff;
        border-bottom: 1px solid #2d2d3f;
    }

        .modal-header .close {
            color: #94a3b8;
            opacity: 1;
        }

            .modal-header .close:hover {
                color: #fff;
            }

    .modal-title {
        font-size: 14px;
        font-weight: 600;
    }

    /* ── Auth ── */
    #authFields .form-control {
        margin-bottom: 6px;
    }

    #authFields label {
        font-size: 11px;
        color: #6b7280;
        margin-bottom: 2px;
        display: block;
    }

    .form-control {
        font-size: 12px;
        height: 34px;
        padding: 5px 10px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
    }

        .form-control:focus {
            border-color: #f97316;
            box-shadow: 0 0 0 2px #fed7aa44;
            outline: none;
        }

    /* ── Notification Toast ── */
    #toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        background: #1e1e2e;
        color: #e2e8f0;
