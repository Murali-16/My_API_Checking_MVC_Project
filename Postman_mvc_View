/* ════════════════════════════════════════
   SEND REQUEST
════════════════════════════════════════ */
function sendRequest() {
    var rawUrl=$('#url').val().trim();
    if(!rawUrl){ alert('Please enter a URL.'); return; }
    var method  =$('#method').val();
    var params  = getKvPairs('pk','pv');
    var hdrs    = getKvPairs('hk','hv');
    var body    =$('#bodyData').val();
    var bodyType=$('#bodyType').val();
    var authType=$('#authType').val();
    if(Object.keys(params).length) rawUrl+='?'+$.param(params);
    if(authType==='basic')  hdrs['Authorization']='Basic ' +btoa($('#authUser').val()+':'+$('#authPass').val());
    if(authType==='bearer') hdrs['Authorization']='Bearer '+$('#authToken').val();
    if(authType==='aws')    hdrs['Authorization']='AWS '   +btoa($('#authAK').val()+':'+$('#authSK').val());
    var apiUrl=method==='GET'?'@Url.Action("SendGetRequest","ApiConsole")':'@Url.Action("SendPostRequest","ApiConsole")';
    $('#page-loader').addClass('show');
    $('#btn-send').addClass('loading').prop('disabled',true);
    $('#response').text('Sending...').css({color:'#9ca3af',fontStyle:'italic'});
    $('#statusBadge').text('--').attr('class','status-badge status-def');
    $('#time,#sizeLabel').text(''); $('#copyBtn').hide();
    var t0=Date.now();
    $.ajax({
        url:apiUrl, type:'POST',
        data:method==='GET'?{Url:rawUrl,Headers:JSON.stringify(hdrs)}:body,
        processData:method==='GET',
        contentType:method==='GET'?'application/x-www-form-urlencoded':(bodyType==='xml'?'application/xml':'application/json'),
        headers:{'Url':rawUrl,'BodyType':bodyType,'CustomHeaders':JSON.stringify(hdrs)},
        success:function(res,_s,xhr){ showResponse(res,xhr.status,t0,xhr); },
        error:function(xhr){ var r=xhr.responseText; try{r=JSON.parse(r);}catch(e){} showResponse(r,xhr.status,t0,xhr); },
        complete:function(){ $('#page-loader').removeClass('show'); $('#btn-send').removeClass('loading').prop('disabled',false); }
    });
}

/* ════════════════════════════════════════
   SHOW RESPONSE
════════════════════════════════════════ */
var statusTextMap={200:'OK',201:'Created',204:'No Content',301:'Moved Permanently',400:'Bad Request',401:'Unauthorized',403:'Forbidden',404:'Not Found',405:'Method Not Allowed',408:'Request Timeout',409:'Conflict',415:'Unsupported Media Type',422:'Unprocessable',429:'Too Many Requests',500:'Internal Server Error',502:'Bad Gateway',503:'Service Unavailable'};
function syntaxHighlightJson(json) {
    var str=JSON.stringify(json,null,4).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return str.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,function(m){
        var cls='jn';
        if(/^"/.test(m)) cls=/:$/.test(m)?'jk':'js';
        else if(/true|false/.test(m)) cls='jb';
        else if(/null/.test(m)) cls='jl';
        return '<span class="'+cls+'">'+m+'</span>';
    });
}
function showResponse(res, status, t0, xhr) {
    var ms=Date.now()-t0;
    var txt=statusTextMap[status]||'Unknown';
    var cls=status>=500?'status-5xx':status>=400?'status-4xx':status>=200?'status-2xx':'status-def';
    resetResTab();
    $('#statusBadge').attr('class','status-badge '+cls).text(status+' '+txt);
    $('#time').text(ms+' ms');
    var isJson=false, formatted='';
    try { var parsed=(typeof res==='object')?res:JSON.parse(res); formatted=syntaxHighlightJson(parsed); isJson=true; }
    catch(e){ formatted=escHtml(String(res)); }
    var rawText=isJson?JSON.stringify(typeof res==='object'?res:JSON.parse(res),null,4):String(res);
    $('#sizeLabel').text((new Blob([rawText]).size/1024).toFixed(2)+' KB');
    $('#response').html(formatted).css({color:'#111827',fontStyle:'normal'});
    $('#copyBtn').show();
    if(xhr&&xhr.getAllResponseHeaders){
        var raw=xhr.getAllResponseHeaders(), hhtml='';
        raw.trim().split('\n').forEach(function(line){
            var parts=line.split(':');
            if(parts.length>=2){ var k=parts[0].trim(),v=parts.slice(1).join(':').trim(); hhtml+='<div class="res-hdr-row"><span class="res-hdr-key">'+escHtml(k)+'</span><span class="res-hdr-val">'+escHtml(v)+'</span></div>'; }
        });
        $('#res-headers-list').html(hhtml||'<span style="color:#9ca3af">No headers available.</span>');
    }
    saveResponseToTab(activeTabId);
}

