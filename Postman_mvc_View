<script>
'use strict';

/* ════════════════════════════════════════
   STATE
════════════════════════════════════════ */
var tabs         = [];
var activeTabId  = null;
var tabCounter   = 0;
var collections  = [];

var STORAGE_KEY  = 'apiconsole_v3';   /* single key stores everything */

/* Context-menu state */
var ctxColId  = null;
var ctxItemId = null;
var ctxMode   = null;  /* 'col' | 'req' */

/* ════════════════════════════════════════
   PERSIST  (single localStorage key)
════════════════════════════════════════ */
function persist() {
    try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
            collections: collections,
            tabs: tabs.map(function(t){ return {
                id:t.id, name:t.name, method:t.method, url:t.url,
                authType:t.authType||'none', authUser:t.authUser||'',
                authPass:t.authPass||'', authToken:t.authToken||'',
                authAK:t.authAK||'', authSK:t.authSK||'',
                bodyType:t.bodyType||'json', bodyData:t.bodyData||'',
                params:t.params||[], headers:t.headers||[],
                innerTab:t.innerTab||0
            }; }),
            activeTabId: activeTabId
        }));
    } catch(e){}
}

function hydrate() {
    try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return false;
        var data = JSON.parse(raw);
        if (data.collections) collections = data.collections;
        if (data.tabs && data.tabs.length) {
            tabs = data.tabs;
            tabCounter = tabs.length + 1;
            activeTabId = data.activeTabId || tabs[0].id;
            return true;
        }
    } catch(e){}
    return false;
}

/* ════════════════════════════════════════
   INIT
════════════════════════════════════════ */
$(function () {
    var restored = hydrate();
    if (!restored) addNewTab();
    else {
        renderTabBar();
        activateTab(activeTabId);
    }
    renderCollections();
    /* global click hides ctx menu */
    $(document).on('click', function(e) {
        if (!$(e.target).closest('#ctx-menu').length) hideCtx();
    });
    /* keyboard */
    $(document).on('keydown', function(e) {
        if (e.key === 'Escape') hideCtx();
        if ((e.ctrlKey||e.metaKey) && e.key === 's') { e.preventDefault(); openSaveModal(); }
        if ((e.ctrlKey||e.metaKey) && e.key === 't') { e.preventDefault(); addNewTab(); }
    });
});

/* ════════════════════════════════════════
   SIDEBAR
════════════════════════════════════════ */
function toggleSidebar() { $('#sidebar').toggleClass('collapsed'); }

/* ════════════════════════════════════════
   TABS
════════════════════════════════════════ */
function addNewTab(name, method, url, params, headers, authData) {
    tabCounter++;
    var id  = 'tab-' + tabCounter;
    var tab = {
        id:id, name:name||'New Request', method:method||'GET', url:url||'',
        authType:(authData&&authData.authType)||'none',
        authUser:(authData&&authData.authUser)||'',
        authPass:(authData&&authData.authPass)||'',
        authToken:(authData&&authData.authToken)||'',
        authAK:(authData&&authData.authAK)||'',
        authSK:(authData&&authData.authSK)||'',
        bodyType:'json', bodyData:'',
        params:params||[], headers:headers||[],
        innerTab:0
    };
    tabs.push(tab);
    renderTabBar();
    activateTab(id);
}

function renderTabBar() {
    $('#tab-bar .req-tab').remove();
    tabs.forEach(function(t) {
        var cls  = methodCls(t.method);
        var html = '<div class="req-tab' + (t.id===activeTabId?' active':'') + '" onclick="activateTab(\''+t.id+'\')" title="'+escHtml(t.name)+'">'
                 + '<span class="tab-method '+cls+'">'+t.method+'</span>'
                 + '<span class="tab-label" style="max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+escHtml(t.name)+'</span>'
                 + '<span class="tab-close" onclick="closeTab(event,\''+t.id+'\')">&#215;</span>'
                 + '</div>';
        $('#btn-new-tab').before(html);
    });
}

function captureTabState(tabId) {
    var t = getTab(tabId); if (!t) return;
    t.method    = $('#method').val();
    t.url       = $('#url').val();
    t.authType  = $('#authType').val();
    t.authUser  = $('#authUser').val()||'';
    t.authPass  = $('#authPass').val()||'';
    t.authToken = $('#authToken').val()||'';
    t.authAK    = $('#authAK').val()||'';
    t.authSK    = $('#authSK').val()||'';
    t.bodyType  = $('#bodyType').val();
    t.bodyData  = $('#bodyData').val();
    t.params    = serializeKv('paramsBody');
    t.headers   = serializeKv('headersBody');
    t.innerTab  = $('.inner-tab.active').index('.inner-tab');
    persist();
}

function saveResponseToTab(tabId) {
    var t = getTab(tabId); if (!t) return;
    t.response = {
        bodyHtml:    $('#response').html(),
        bodyStyle:   { color:$('#response').css('color'), fontStyle:$('#response').css('font-style') },
        statusText:  $('#statusBadge').text(),
        statusClass: $('#statusBadge').attr('class'),
        time:        $('#time').text(),
        size:        $('#sizeLabel').text(),
        copyVisible: $('#copyBtn').is(':visible'),
        headerHtml:  $('#res-headers-list').html()
    };
}

function restoreResponseFromTab(t) {
    resetResTab();
    if (!t.response) {
        $('#response').html('Response will appear here...').css({color:'#9ca3af',fontStyle:'italic'});
        $('#statusBadge').attr('class','status-badge status-def').text('--');
        $('#time, #sizeLabel').text(''); $('#copyBtn').hide(); $('#res-headers-list').html('');
        return;
    }
    var r = t.response;
    $('#response').html(r.bodyHtml).css(r.bodyStyle);
    $('#statusBadge').attr('class',r.statusClass).text(r.statusText);
    $('#time').text(r.time); $('#sizeLabel').text(r.size);
    r.copyVisible ? $('#copyBtn').show() : $('#copyBtn').hide();
    $('#res-headers-list').html(r.headerHtml||'');
}

function activateTab(id) {
    if (activeTabId && activeTabId !== id) { captureTabState(activeTabId); saveResponseToTab(activeTabId); }
    activeTabId = id;
    var t = getTab(id); if (!t) return;
    restoreTabState(t);
    renderTabBar();
    persist();
}

function closeTab(e, id) {
    e.stopPropagation();
    if (activeTabId === id) captureTabState(id);
    tabs = tabs.filter(function(t){ return t.id!==id; });
    if (!tabs.length) { addNewTab(); return; }
    if (activeTabId === id) activateTab(tabs[tabs.length-1].id);
    else renderTabBar();
    persist();
}

function restoreTabState(t) {
    $('#method').val(t.method||'GET');
    $('#url').val(t.url||'');
    onMethodChange();
    $('#authType').val(t.authType||'none');
    renderAuthFields();
    if (t.authUser)  try{ $('#authUser').val(t.authUser); }catch(e){}
    if (t.authPass)  try{ $('#authPass').val(t.authPass); }catch(e){}
    if (t.authToken) try{ $('#authToken').val(t.authToken); }catch(e){}
    if (t.authAK)    try{ $('#authAK').val(t.authAK); }catch(e){}
    if (t.authSK)    try{ $('#authSK').val(t.authSK); }catch(e){}
    $('#bodyType').val(t.bodyType||'json');
    $('#bodyData').val(t.bodyData||'');
    onBodyInput();
    restoreKv('paramsBody','pk','pv',t.params,true);
    restoreKv('headersBody','hk','hv',t.headers,false);
    var panels=['it-params','it-auth','it-headers','it-body'];
    var idx=t.innerTab||0;
    $('.inner-tab').removeClass('active'); $('.inner-tab-content').removeClass('active');
    $('.inner-tab').eq(idx).addClass('active'); $('#'+panels[idx]).addClass('active');
    /* update name bar */
    $('#req-display-name').text(t.name||'New Request');
    updateBreadcrumb(t);
    restoreResponseFromTab(t);
}

function syncActiveTab() {
    var t = getTab(activeTabId); if (!t) return;
    t.url    = $('#url').val();
    t.method = $('#method').val();
    var parts = t.url.replace(/\?.*/,'').split('/').filter(Boolean);
    /* only auto-name if still the default */
    if (t.name === 'New Request' || t.name === '') {
        t.name = parts.length ? parts[parts.length-1] : 'New Request';
        $('#req-display-name').text(t.name);
    }
    renderTabBar();
}

function onMethodChange() {
    syncActiveTab();
    var m = $('#method').val();
    var colMap={GET:'#1d4ed8',POST:'#065f46',PUT:'#92400e',DELETE:'#991b1b',PATCH:'#5b21b6'};
    $('#method').css('color', colMap[m]||'#374151');
}

function getTab(id){ return tabs.find(function(t){ return t.id===id; }); }

/* breadcrumb: shows which collection the active tab belongs to */
function updateBreadcrumb(t) {
    var found = '';
    collections.forEach(function(col) {
        col.items.forEach(function(item) {
            if (item.name === t.name && item.url === t.url && item.method === t.method) found = col.name;
        });
    });
    $('#req-breadcrumb').text(found ? '— '+found : '');
}

/* ════════════════════════════════════════
   KV ROWS
════════════════════════════════════════ */
function addKvRow(tbodyId, keyClass, valClass) {
    var desc = tbodyId==='paramsBody' ? '<td><input type="text" placeholder="Description"></td>' : '';
    var row  = '<tr>'
             + '<td style="width:28px"><input type="checkbox" checked style="accent-color:#f97316"></td>'
             + '<td><input type="text" class="'+keyClass+'" placeholder="Key"></td>'
             + '<td><input type="text" class="'+valClass+'" placeholder="Value"></td>'
             + desc
             + '<td style="width:28px"><button class="btn-del-row" onclick="$(this).closest(\'tr\').remove()">&#215;</button></td>'
             + '</tr>';
    $('#'+tbodyId).append(row);
}

function serializeKv(tbodyId) {
    var rows=[];
    $('#'+tbodyId+' tr').each(function() {
        var cells=$(this).find('input[type="text"]');
        rows.push({ key:cells.eq(0).val(), value:cells.eq(1).val(), desc:cells.eq(2).val()||'', enabled:$(this).find('input[type="checkbox"]').prop('checked') });
    });
    return rows;
}

function restoreKv(tbodyId, keyClass, valClass, rows, hasDesc) {
    $('#'+tbodyId).empty();
    if (!rows||!rows.length){ addKvRow(tbodyId,keyClass,valClass); return; }
    rows.forEach(function(r) {
        var desc = hasDesc ? '<td><input type="text" placeholder="Description" value="'+escHtml(r.desc||'')+'"></td>' : '';
        var row  = '<tr>'
                 + '<td style="width:28px"><input type="checkbox"'+(r.enabled?' checked':'')+' style="accent-color:#f97316"></td>'
                 + '<td><input type="text" class="'+keyClass+'" placeholder="Key" value="'+escHtml(r.key||'')+'"></td>'
                 + '<td><input type="text" class="'+valClass+'" placeholder="Value" value="'+escHtml(r.value||'')+'"></td>'
                 + desc
                 + '<td style="width:28px"><button class="btn-del-row" onclick="$(this).closest(\'tr\').remove()">&#215;</button></td>'
                 + '</tr>';
        $('#'+tbodyId).append(row);
    });
}

function getKvPairs(keyClass, valClass) {
    var data={};
    $('.'+keyClass).each(function(i){
        var k=$(this).val().trim(), v=$('.'+valClass).eq(i).val().trim();
        var checked=$(this).closest('tr').find('input[type="checkbox"]').prop('checked');
        if(k&&checked) data[k]=v;
    });
    return data;
}

/* ════════════════════════════════════════
   AUTH
════════════════════════════════════════ */
function renderAuthFields() {
    var type=$('#authType').val(), html='';
    if(type==='basic') {
        html='<div class="row"><div class="col-md-6"><label>Username</label><input id="authUser" class="form-control"></div>'
            +'<div class="col-md-6"><label>Password</label><input id="authPass" type="password" class="form-control"></div></div>';
    } else if(type==='bearer') {
        html='<label>Token</label><input id="authToken" class="form-control" placeholder="Bearer token...">';
    } else if(type==='aws') {
        html='<div class="row"><div class="col-md-6"><label>Access Key</label><input id="authAK" class="form-control"></div>'
            +'<div class="col-md-6"><label>Secret Key</label><input id="authSK" type="password" class="form-control"></div></div>';
    }
    $('#authFields').html(html);
}

/* ════════════════════════════════════════
   BODY
════════════════════════════════════════ */
function detectBodyType(raw) {
    var s=raw.trim(); if(!s) return 'text';
    if(s[0]==='{' || s[0]==='['){try{JSON.parse(s);return 'json';}catch(e){}}
    if(s[0]==='<') return 'xml';
    return 'text';
}
function onBodyInput() {
    var raw=$('#bodyData').val(), type=detectBodyType(raw);
    $('#bodyType').val(type);
    var labels={json:'&#9679; JSON',xml:'&#9679; XML',text:'&#9679; Text'};
    var cls={json:'detect-json',xml:'detect-xml',text:'detect-text'};
    var badge=$('#bodyDetectBadge');
    if(raw.trim()){ badge.attr('class','detect-badge '+cls[type]).html(labels[type]).show(); validateBody(raw,type); }
    else { badge.hide(); $('#bodyValidMsg').text(''); }
}
function onBodyTypeChange(){ var raw=$('#bodyData').val().trim(); if(raw) validateBody(raw,$('#bodyType').val()); }
function validateBody(raw,type) {
    var msg=$('#bodyValidMsg');
    if(type==='json'){ try{JSON.parse(raw);msg.text('✔ Valid JSON').css('color','#065f46');}catch(e){msg.text('✖ '+e.message.split('\n')[0]).css('color','#991b1b');} }
    else if(type==='xml'){ var doc=new DOMParser().parseFromString(raw,'application/xml'); doc.querySelector('parsererror')?msg.text('✖ Invalid XML').css('color','#991b1b'):msg.text('✔ Valid XML').css('color','#065f46'); }
    else { msg.text(''); }
}
function beautifyBody() {
    var raw=$('#bodyData').val().trim(); if(!raw) return;
    var type=detectBodyType(raw); $('#bodyType').val(type);
    if(type==='json'){ try{$('#bodyData').val(JSON.stringify(JSON.parse(raw),null,4));flashTA(true);}catch(e){$('#bodyValidMsg').text('✖ '+e.message).css('color','#991b1b');flashTA(false);return;} }
    else if(type==='xml'){ try{$('#bodyData').val(beautifyXml(raw));flashTA(true);}catch(e){$('#bodyValidMsg').text('✖ Invalid XML').css('color','#991b1b');flashTA(false);return;} }
    else { $('#bodyValidMsg').text('Nothing to beautify for plain text.').css('color','#6b7280'); return; }
    onBodyInput();
}
function clearBody(){ $('#bodyData').val(''); $('#bodyDetectBadge').hide(); $('#bodyValidMsg').text(''); }
function flashTA(ok){ var c=ok?'flash-ok':'flash-error'; $('#bodyData').addClass(c); setTimeout(function(){ $('#bodyData').removeClass(c); },600); }
function beautifyXml(xml) {
    var doc=new DOMParser().parseFromString(xml,'application/xml');
    if(doc.querySelector('parsererror')) throw new Error('Invalid XML');
    return serXml(doc.documentElement,0);
}
function serXml(node,depth) {
    var pad='    '.repeat(depth), out='';
    if(node.nodeType===3){ var t=node.nodeValue.trim(); return t?pad+t+'\n':''; }
    if(node.nodeType===8){ return pad+'<!--'+node.nodeValue+'-->\n'; }
    var tag=node.tagName, attrs='';
    for(var i=0;i<node.attributes.length;i++){ var a=node.attributes[i]; attrs+=' '+a.name+'="'+a.value+'"'; }
    var kids=Array.from(node.childNodes);
    if(!kids.length) return pad+'<'+tag+attrs+'/>\n';
    if(kids.length===1&&kids[0].nodeType===3) return pad+'<'+tag+attrs+'>'+kids[0].nodeValue.trim()+'</'+tag+'>\n';
    out=pad+'<'+tag+attrs+'>\n';
    kids.forEach(function(c){ out+=serXml(c,depth+1); });
    return out+pad+'</'+tag+'>\n';
}

