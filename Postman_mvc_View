   CONTEXT MENU
════════════════════════════════════════ */
function showCtxCol(e, colId) {
    e.preventDefault(); e.stopPropagation();
    ctxColId=colId; ctxItemId=null; ctxMode='col';
    $('#ctx-rename-col,#ctx-add-req,#ctx-sep-1,#ctx-del-col').show();
    $('#ctx-rename-req,#ctx-edit-req,#ctx-dup-req,#ctx-sep-2,#ctx-del-req').hide();
    positionCtx(e);
}
function showCtxReq(e, colId, itemId) {
    e.preventDefault(); e.stopPropagation();
    ctxColId=colId; ctxItemId=itemId; ctxMode='req';
    $('#ctx-rename-col,#ctx-add-req,#ctx-sep-1,#ctx-del-col').hide();
    $('#ctx-rename-req,#ctx-edit-req,#ctx-dup-req,#ctx-sep-2,#ctx-del-req').show();
    positionCtx(e);
}
function positionCtx(e) {
    var menu=$('#ctx-menu');
    menu.css({ display:'block', left:e.clientX, top:e.clientY });
    /* keep inside viewport */
    var r=menu[0].getBoundingClientRect();
    if(r.right>window.innerWidth)  menu.css('left', e.clientX-r.width);
    if(r.bottom>window.innerHeight) menu.css('top', e.clientY-r.height);
}
function hideCtx(){ $('#ctx-menu').hide(); ctxColId=null; ctxItemId=null; ctxMode=null; }
function ctxAction(action) {
    hideCtx();
    if(action==='rename-col')  openRenameColModal(ctxColId);
    else if(action==='add-req')     openAddReqModal(ctxColId);
    else if(action==='del-col')     deleteCollection(ctxColId);
    else if(action==='rename-req')  openRenameReqInCol(ctxColId,ctxItemId);
    else if(action==='edit-req')    { openEditReqModal(ctxColId,ctxItemId); }
    else if(action==='dup-req')     duplicateColItem(ctxColId,ctxItemId);
    else if(action==='del-req')     deleteColItem(ctxColId,ctxItemId);
}

