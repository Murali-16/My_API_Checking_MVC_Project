function renderCollections() {
    if (!collections.length) {
        $('#collection-list').html('<div class="sidebar-empty"><div class="empty-icon">📂</div>No collections yet.<br>Click <b>+ New</b> to create one.</div>');
        return;
    }
    var html='';
    collections.forEach(function(col) {
        var count=col.items.length;
        html+='<div class="col-group" id="cg-'+col.id+'">';
        /* header row */
        html+='<div class="col-group-hdr '+(col.open?'open':'')+'" '
             +'onclick="toggleCollection(\''+col.id+'\')" '
             +'oncontextmenu="showCtxCol(event,\''+col.id+'\')">'
             +'<span class="col-icon">&#9654;</span>'
             +'<span class="col-name" title="'+escHtml(col.name)+'">'+escHtml(col.name)+'</span>'
             +'<span class="col-count">'+count+'</span>'
             +'<div class="col-actions" onclick="event.stopPropagation()">'
             +'  <button class="col-act-btn" onclick="openRenameColModal(\''+col.id+'\')" title="Rename">✏️</button>'
             +'  <button class="col-act-btn" onclick="openAddReqModal(\''+col.id+'\')" title="Add request">➕</button>'
             +'  <button class="col-act-btn danger" onclick="deleteCollection(\''+col.id+'\')" title="Delete">🗑</button>'
             +'</div>'
             +'</div>';
        /* items */
        html+='<div class="col-items '+(col.open?'open':'')+'" id="ci-'+col.id+'">';
        if (!col.items.length) {
            html+='<div style="padding:6px 12px 6px 28px;font-size:11px;color:#475569;font-style:italic">No requests yet</div>';
        }
        col.items.forEach(function(item) {
            var cls=methodCls(item.method);
            html+='<div class="col-item" id="cii-'+item.id+'" '
                 +'onclick="loadItem(\''+col.id+'\',\''+item.id+'\')" '
                 +'oncontextmenu="showCtxReq(event,\''+col.id+'\',\''+item.id+'\')">'
                 +'<span class="item-method '+cls+'">'+item.method+'</span>'
                 +'<span class="item-name" title="'+escHtml(item.name)+'">'+escHtml(item.name)+'</span>'
                 +'<div class="item-actions" onclick="event.stopPropagation()">'
                 +'  <button class="item-act-btn" onclick="openEditReqModal(\''+col.id+'\',\''+item.id+'\')" title="Edit">✏️</button>'
                 +'  <button class="item-act-btn danger" onclick="deleteColItem(\''+col.id+'\',\''+item.id+'\')" title="Delete">🗑</button>'
                 +'</div>'
                 +'</div>';
        });
        html+='</div></div>';
    });
    $('#collection-list').html(html);
}

